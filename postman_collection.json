    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "API Health",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/api/health", "host": ["{{base_url}}"], "path": ["api","health"] } }
        }
      ]
