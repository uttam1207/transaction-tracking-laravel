{
  "info": {
    "name": "Transaction Monitor API v1",
    "_postman_id": "txmonitor-api-v1",
    "description": "Complete REST API for Transaction Monitoring System with User Management & Employee Work Tracking.\n\nBase URL: {{base_url}}/api/v1\n\nAuthentication: Bearer Token (Sanctum)\nAdd header: Authorization: Bearer {{token}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000", "type": "string" },
    { "key": "token",    "value": "",                       "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api","v1","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@demo.com\",\n  \"password\": \"Admin@123\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/register", "host": ["{{base_url}}"], "path": ["api","v1","auth","register"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@123\",\n  \"password_confirmation\": \"Password@123\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Me (Profile)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/me", "host": ["{{base_url}}"], "path": ["api","v1","auth","me"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/logout", "host": ["{{base_url}}"], "path": ["api","v1","auth","logout"] }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/refresh", "host": ["{{base_url}}"], "path": ["api","v1","auth","refresh"] }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Admin Stats",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/dashboard/admin-stats", "host": ["{{base_url}}"], "path": ["api","v1","dashboard","admin-stats"] } }
        },
        {
          "name": "Employee Stats",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/dashboard/employee-stats", "host": ["{{base_url}}"], "path": ["api","v1","dashboard","employee-stats"] } }
        },
        {
          "name": "Chart Data",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/dashboard/chart-data?period=month", "host": ["{{base_url}}"], "path": ["api","v1","dashboard","chart-data"], "query": [{ "key": "period", "value": "month" }] } }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "List Transactions",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/transactions?page=1&per_page=15&status=pending", "host": ["{{base_url}}"], "path": ["api","v1","transactions"], "query": [{ "key": "page","value":"1"},{"key":"per_page","value":"15"},{"key":"status","value":"pending"}] } }
        },
        {
          "name": "Create Transaction",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/transactions", "host": ["{{base_url}}"], "path": ["api","v1","transactions"] },
            "body": { "mode": "raw", "raw": "{\n  \"category\": \"transfer\",\n  \"type\": \"debit\",\n  \"amount\": 1500.00,\n  \"currency\": \"USD\",\n  \"fee\": 2.50,\n  \"payment_method\": \"bank_transfer\",\n  \"sender_name\": \"John Doe\",\n  \"sender_account\": \"1234567890\",\n  \"sender_bank\": \"First National Bank\",\n  \"receiver_name\": \"Jane Smith\",\n  \"receiver_account\": \"0987654321\",\n  \"receiver_bank\": \"City Bank\",\n  \"reference\": \"INV-2024-001\",\n  \"country\": \"US\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Get Transaction",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/transactions/1", "host": ["{{base_url}}"], "path": ["api","v1","transactions","1"] } }
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/transactions/1", "host": ["{{base_url}}"], "path": ["api","v1","transactions","1"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"success\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Transaction Statistics",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/transactions/statistics?period=month", "host": ["{{base_url}}"], "path": ["api","v1","transactions","statistics"], "query": [{ "key": "period", "value": "month" }] } }
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "List Attendance",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/attendance", "host": ["{{base_url}}"], "path": ["api","v1","attendance"] } }
        },
        {
          "name": "Today's Attendance",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/attendance/today", "host": ["{{base_url}}"], "path": ["api","v1","attendance","today"] } }
        },
        {
          "name": "Check In",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/attendance/check-in", "host": ["{{base_url}}"], "path": ["api","v1","attendance","check-in"] },
            "body": { "mode": "raw", "raw": "{\n  \"notes\": \"On time\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Check Out",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/attendance/check-out", "host": ["{{base_url}}"], "path": ["api","v1","attendance","check-out"] },
            "body": { "mode": "raw", "raw": "{\n  \"notes\": \"Work completed\"\n}", "options": { "raw": { "language": "json" } } }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List Tasks",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/tasks?status=in_progress&priority=high", "host": ["{{base_url}}"], "path": ["api","v1","tasks"], "query": [{ "key": "status", "value": "in_progress" }, { "key": "priority", "value": "high" }] } }
        },
        {
          "name": "Get Task",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/tasks/1", "host": ["{{base_url}}"], "path": ["api","v1","tasks","1"] } }
        },
        {
          "name": "Update Task Status",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/tasks/1/status", "host": ["{{base_url}}"], "path": ["api","v1","tasks","1","status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"completed\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/tasks/1/comments", "host": ["{{base_url}}"], "path": ["api","v1","tasks","1","comments"] },
            "body": { "mode": "raw", "raw": "{\n  \"comment\": \"Task completed as per requirements.\"\n}", "options": { "raw": { "language": "json" } } }
          }
        }
      ]
    },
    {
      "name": "Work Reports",
      "item": [
        {
          "name": "List Work Reports",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/work-reports?month=5&year=2026", "host": ["{{base_url}}"], "path": ["api","v1","work-reports"], "query": [{ "key": "month", "value": "5" }, { "key": "year", "value": "2026" }] } }
        },
        {
          "name": "Create Work Report",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/work-reports", "host": ["{{base_url}}"], "path": ["api","v1","work-reports"] },
            "body": { "mode": "raw", "raw": "{\n  \"report_date\": \"2026-05-28\",\n  \"summary\": \"Completed API integration for payment module and fixed 3 critical bugs.\",\n  \"hours_worked\": 8.5,\n  \"tasks_completed\": [\"API integration\", \"Bug fixes\", \"Code review\"],\n  \"productivity_score\": 90,\n  \"submit\": true\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Get Work Report",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/work-reports/1", "host": ["{{base_url}}"], "path": ["api","v1","work-reports","1"] } }
        },
        {
          "name": "Submit Work Report",
          "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/work-reports/1/submit", "host": ["{{base_url}}"], "path": ["api","v1","work-reports","1","submit"] } }
        }
      ]
    },
    {
      "name": "Fraud Alerts (Admin)",
      "item": [
        {
          "name": "Statistics",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/fraud-alerts/statistics", "host": ["{{base_url}}"], "path": ["api","v1","fraud-alerts","statistics"] } }
        },
        {
          "name": "List Fraud Alerts",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/fraud-alerts?status=open&severity=high", "host": ["{{base_url}}"], "path": ["api","v1","fraud-alerts"], "query": [{ "key": "status", "value": "open" }, { "key": "severity", "value": "high" }] } }
        },
        {
          "name": "Get Fraud Alert",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/fraud-alerts/1", "host": ["{{base_url}}"], "path": ["api","v1","fraud-alerts","1"] } }
        },
        {
          "name": "Assign Alert",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/fraud-alerts/1/assign", "host": ["{{base_url}}"], "path": ["api","v1","fraud-alerts","1","assign"] },
            "body": { "mode": "raw", "raw": "{\n  \"assigned_to\": 2\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Resolve Alert",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/fraud-alerts/1/resolve", "host": ["{{base_url}}"], "path": ["api","v1","fraud-alerts","1","resolve"] },
            "body": { "mode": "raw", "raw": "{\n  \"action\": \"resolved\",\n  \"resolution_notes\": \"Verified with customer — legitimate transaction.\"\n}", "options": { "raw": { "language": "json" } } }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List Notifications",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/notifications", "host": ["{{base_url}}"], "path": ["api","v1","notifications"] } }
        },
        {
          "name": "Mark Read",
          "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{base_url}}/api/v1/notifications/1/read", "host": ["{{base_url}}"], "path": ["api","v1","notifications","1","read"] } }
        },
